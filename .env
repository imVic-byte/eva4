# Servidor
PORT=3000
NODE_ENV=development
JWT_SECRET=cambiar_esta_clave_en_produccion
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5173

# Base de datos: sqlite o mysql
DB_DIALECT=mysql

# SQLite por defecto
SQLITE_STORAGE=./database/galeria.sqlite

# MySQL opcional
DB_HOST=localhost
DB_PORT=3306
DB_NAME=galeria_fotos
DB_USER=root
DB_PASSWORD=

# Archivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
